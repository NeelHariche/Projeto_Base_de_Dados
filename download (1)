-- 1. ENTIDADES (NOMES NO PLURAL)
-------------------------------------------------------------------------

CREATE TABLE Movies (
    movieID INT PRIMARY KEY,
    movieName VARCHAR(200) NOT NULL, -- Atributos no singular
    movieBudget DECIMAL(15,2),                  
    movieDuration INT,
    movieReleaseDate DATE,                      
    movieRatingCount INT,
    movieRating DECIMAL(3,1),
    ageRatingID INT,                            
    countryID INT,                              
    interactionDate DATE DEFAULT ('2026-01-01') 
);
GO

CREATE TABLE Genres (
    genreID INT PRIMARY KEY,
    genreName VARCHAR(100) NOT NULL
);
GO

CREATE TABLE Actors (
    actorID INT PRIMARY KEY,
    actorName VARCHAR(150) NOT NULL,
    actorGender CHAR(1) CHECK (actorGender IN ('M','F'))
);
GO

CREATE TABLE Directors (
    directorID INT PRIMARY KEY,
    directorName VARCHAR(150) NOT NULL
);
GO

-- 2. TABELAS DE LIGAÇÃO (NOMES NO PLURAL)
-------------------------------------------------------------------------

CREATE TABLE MovieGenres (
    movieID INT NOT NULL,
    genreID INT NOT NULL,
    PRIMARY KEY (movieID, genreID),
    CONSTRAINT FK_MovieGenres_Movies FOREIGN KEY (movieID) REFERENCES Movies(movieID),
    CONSTRAINT FK_MovieGenres_Genres FOREIGN KEY (genreID) REFERENCES Genres(genreID)
);
GO

CREATE TABLE MovieActors (
    movieID INT NOT NULL,
    actorID INT NOT NULL,
    PRIMARY KEY (movieID, actorID),
    CONSTRAINT FK_MovieActors_Movies FOREIGN KEY (movieID) REFERENCES Movies(movieID),
    CONSTRAINT FK_MovieActors_Actors FOREIGN KEY (actorID) REFERENCES Actors(actorID)
);
GO

CREATE TABLE MovieDirectors (
    movieID INT NOT NULL,
    directorID INT NOT NULL,
    PRIMARY KEY (movieID, directorID),
    CONSTRAINT FK_MovieDirectors_Movies FOREIGN KEY (movieID) REFERENCES Movies(movieID),
    CONSTRAINT FK_MovieDirectors_Directors FOREIGN KEY (directorID) REFERENCES Directors(directorID)
);
GO

