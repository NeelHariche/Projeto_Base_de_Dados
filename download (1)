-- 4.1: Listar vídeos de um certo género
SELECT M.movieID, M.movieName, G.genreName
FROM Movies M 
JOIN MovieGenres MG ON M.movieID = MG.movieID
JOIN Genres G ON MG.genreID = G.genreID
WHERE TRIM(G.genreName) = 'Action'; 
GO

-- 4.2: Listar realizadores de vídeos produzidos num país
SELECT DISTINCT D.directorID, D.directorName
FROM Directors D 
JOIN MovieDirectors MD ON D.directorID = MD.directorID
JOIN Movies M ON MD.movieID = M.movieID
JOIN Countries C ON M.countryID = C.countryID
WHERE C.countryName = 'Estados Unidos'; -- 'França' daria 0 porque todos estão como USA
GO

SELECT DISTINCT D.directorID, D.directorName
FROM Directors D 
JOIN MovieDirectors MD ON D.directorID = MD.directorID
JOIN Movies M ON MD.movieID = M.movieID
JOIN Countries C ON M.countryID = C.countryID
WHERE C.countryName = 'França'; -- Daria 0 porque todos estão como USA
GO

-- 4.3: Listar atores Masculinos em filmes de países Asiáticos
SELECT DISTINCT A.actorID, A.actorName
FROM Actors A 
JOIN MovieActors MA ON A.actorID = MA.actorID
JOIN Movies M ON MA.movieID = M.movieID
JOIN Countries C_o ON M.countryID = C_o.countryID
JOIN Continents C_e ON C_o.continentID = C_e.continentID
WHERE A.actorGender = 'M' AND C_e.continentName = 'América do Norte';
GO

-- 4.4: Listar vídeos lançados em Maio, Junho e Julho
SELECT M.movieID, M.movieName, M.movieReleaseDate
FROM Movies M
WHERE MONTH(M.movieReleaseDate) IN (5, 6, 7);
GO

-- 4.5: Listar vídeos de Ação, Europeus, lançados em Dezembro
SELECT M.movieID, M.movieName, M.movieReleaseDate
FROM Movies M 
JOIN MovieGenres MG ON M.movieID = MG.movieID
JOIN Genres G ON MG.genreID = G.genreID
JOIN Countries C_o ON M.countryID = C_o.countryID
JOIN Continents C_e ON C_o.continentID = C_e.continentID
WHERE (G.genreName = 'Ação' OR G.genreName = 'Action') 
  AND C_e.continentName = 'Europa' 
  AND MONTH(M.movieReleaseDate) = 12;
GO

-- 4.6: Listar vídeos para maiores de 18
SELECT M.movieID, M.movieName, AR.ageRatingName 
FROM Movies M 
JOIN AgeRatings AR ON M.ageRatingID = AR.ageRatingID
WHERE AR.ageRatingName = '+18';
GO

-- 4.7: Contar vídeos para menores de 10, por Continente
SELECT C_e.continentName, COUNT(*) AS totalVideosLess10
FROM Movies M 
JOIN AgeRatings AR ON M.ageRatingID = AR.ageRatingID
JOIN Countries C_o ON M.countryID = C_o.countryID
JOIN Continents C_e ON C_o.continentID = C_e.continentID
WHERE AR.ageRatingName = '<10'
GROUP BY C_e.continentName;
GO

-- 4.8: Contar vídeos para +18, por País da Europa
SELECT C_o.countryName, COUNT(*) AS totalVideos18Plus
FROM Movies M 
JOIN AgeRatings AR ON M.ageRatingID = AR.ageRatingID
JOIN Countries C_o ON M.countryID = C_o.countryID
JOIN Continents C_e ON C_o.continentID = C_e.continentID
WHERE AR.ageRatingName = '+18' AND C_e.continentName = 'América do Norte'
GROUP BY C_o.countryName;
GO

-- 4.9: Top 10 diretores com melhor rating médio
SELECT TOP 10 D.directorName, AVG(M.movieRating) AS mediaRating
FROM Directors D 
JOIN MovieDirectors MD ON D.directorID = MD.directorID
JOIN Movies M ON MD.movieID = M.movieID
GROUP BY D.directorName
ORDER BY mediaRating DESC;
GO